# Supabase (get from your project's API settings)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres connection for Drizzle migrations. Prefer the Session pooler (IPv4-
# friendly); the direct db.<ref> host is IPv6-only and can fail on IPv4 networks.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Google Maps (documented now, used in Phase 1). Restrict the key per README.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key

# Dev phone-OTP stub code (Phase 0 only; real SMS provider comes later).
DEV_PHONE_OTP_CODE=000000
